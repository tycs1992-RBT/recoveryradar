# Database
# Local Docker Postgres uses this URL. For Vercel, replace with your Neon/Postgres connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recovery_radar?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/recovery_radar?schema=public"

# Auth for private workspace
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
DEMO_ADMIN_EMAIL="founders@infinitepieces.ai"
DEMO_ADMIN_PASSWORD="replace-with-private-password"
DEMO_ADMIN_NAME="Founders"

# Production domain notes
# In Vercel for infinitepieces.ai, use:
# NEXTAUTH_URL="https://www.infinitepieces.ai"
# NEXT_PUBLIC_SITE_URL="https://www.infinitepieces.ai"
# NEXT_PUBLIC_DEMO_URL="https://www.infinitepieces.ai"
# DEMO_URL="https://www.infinitepieces.ai"

# Public site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="Infinite Pieces AI"
NEXT_PUBLIC_PRODUCT_NAME="Infinite Suite OS"
NEXT_PUBLIC_DEMO_URL="http://localhost:3000"
DEMO_URL="http://localhost:3000"

# AI and search integrations
# OpenAI powers public Recovery Advisor Q&A and private content drafts.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Google Places powers Lead Machine business names, phones, websites, addresses and maps links.
GOOGLE_PLACES_API_KEY=""

# SerpApi powers Intent Crawler and SERP Checker. Preferred over Google Custom Search.
SERPAPI_API_KEY=""

# Optional Google Custom Search fallback for crawler/SERP only.
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_CX=""

# Optional CRM/email integrations
HUBSPOT_PRIVATE_APP_TOKEN=""
HUBSPOT_PORTAL_ID=""
RESEND_API_KEY=""
EMAIL_FROM="Infinite Pieces AI <founders@infinitepieces.ai>"
COMMERCIAL_POSTAL_ADDRESS="Infinite Pieces AI, address pending"

# --- Real provider login (Tyler's full Infinite Suite OS workspace) ---
# This repo is PUBLIC — the real password must live here in Vercel env, NOT in code.
# Local dev falls back to a built-in dev value; set these for production.
PROVIDER_LOGIN_EMAIL=tyler@infinitepieces.ai
PROVIDER_LOGIN_PASSWORD=
PROVIDER_LOGIN_NAME=Tyler — Infinite Pieces AI
