# Database
# Local Docker Postgres uses this URL. If you are only exploring the public demo, you can run npm run dev without db:push/db:seed.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recovery_radar?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/recovery_radar?schema=public"

# Auth for private workspace
# For now you and Mark can share this login. Change before public deployment.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
DEMO_ADMIN_EMAIL="founders@infinitepieces.ai"
DEMO_ADMIN_PASSWORD="infinitemark2026"
DEMO_ADMIN_NAME="Founders"

# Cloudflare deployment notes
# When routed through Cloudflare, set these in your hosting provider / Cloudflare Pages environment:
# NEXTAUTH_URL="https://demo.infinitepieces.ai"
# NEXT_PUBLIC_SITE_URL="https://demo.infinitepieces.ai"
# Keep workspace routes private behind this app login and optionally Cloudflare Access.

# Optional AI and search integrations
# OPENAI_API_KEY powers the public Recovery Advisor Q&A and content drafts.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
# GOOGLE_SEARCH_API_KEY + GOOGLE_SEARCH_CX power the private EMR Buyer Intent Crawler.
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_CX=""
# GOOGLE_PLACES_API_KEY powers the simpler Lead Machine for business names, phones, websites and addresses.
GOOGLE_PLACES_API_KEY=""

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="Infinite Pieces AI"
NEXT_PUBLIC_PRODUCT_NAME="Infinite Suite OS"

# Optional future integrations
HUBSPOT_PRIVATE_APP_TOKEN=""
HUBSPOT_PORTAL_ID=""
RESEND_API_KEY=""
EMAIL_FROM="Infinite Pieces AI <founders@infinitepieces.ai>"
COMMERCIAL_POSTAL_ADDRESS="Infinite Pieces AI, address pending"
DEMO_URL="https://demo.infinitepieces.ai"
